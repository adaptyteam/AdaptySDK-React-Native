# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

# Required for spm_dependency in react-native-adapty (RN 0.75+ SPM integration).
use_frameworks! :linkage => :dynamic

target 'AdaptyRnSdkExample' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )

    # Adapty Kids Mode (COPPA / Kids Category): opt-in via `ADAPTY_KIDS_MODE=1 pod install`.
    # The helper sets the `KidsMode` SPM trait on the AdaptySDK-iOS package reference that
    # `spm_dependency` creates in the Pods project. It MUST run after react_native_post_install,
    # which wipes and recreates all package references on every pod install. No-op otherwise.
    if ENV['ADAPTY_KIDS_MODE'] == '1'
      require Pod::Executable.execute_command('node', ['-p',
        'require.resolve(
          "react-native-adapty/ios/adapty_kids_mode.rb",
          {paths: [process.argv[1]]},
        )', __dir__]).strip
      adapty_enable_kids_mode(installer)
    end
  end
end
